# Real-Time Video/Audio Summarizer Configuration

# Gemini API Key (Required for AI summaries. Get a free key at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration (SQLite)
DATABASE_URL=sqlite:///./summarizer.db

# Whisper Model size (options: tiny, base, small, medium, large-v3)
# 'base' is recommended for a balance of speed and accuracy on consumer CPUs (~145MB)
WHISPER_MODEL=base

# Directory to temporarily store uploaded audio/video files
UPLOAD_DIR=./uploads

# Backend Server Configuration
HOST=0.0.0.0
PORT=8000
